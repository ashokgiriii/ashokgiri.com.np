# Email Configuration (SMTP)
# Configure these environment variables to enable email sending

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Email Addresses
MAIL_FROM=your-email@gmail.com
CONTACT_RECEIVER=recipient@example.com

# Server Configuration
PORT=10000

# Development Settings
NODE_ENV=development
# Set to "true" to log contact messages to console instead of sending emails (dev only)
CONTACT_DEV_LOG_ONLY=false
